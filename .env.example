# ============================================================
# FormaFlow — Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit the .env file to source control.
# ============================================================

# ── APS / Autodesk Platform Services ──────────────────────
# Obtain from https://aps.autodesk.com/myapps/
APS_CLIENT_ID=your_aps_client_id_here
APS_CLIENT_SECRET=your_aps_client_secret_here

# ── 3-Legged OAuth callback URL (WEB APP TYPE ONLY) ───────
# Only required if your APS app type is "Web App" (not Server-to-Server / S2S).
# Must EXACTLY match a Callback URL registered in your APS app settings.
# For Railway: https://your-app.railway.app/api/auth/callback
# For local dev: http://localhost:3000/api/auth/callback  (default if not set)
#
# NOTE: Model Coordination API (Search Sets, Clash Tests) requires a 3-legged
# OAuth token — 2-legged S2S tokens will receive 403 from the MC API.
# To use FormaFlow's full MC features you need a Web App type APS credential
# that can complete the authorization code flow below, OR wait for Autodesk
# SSA (Secure Service Accounts) to add MC API support (currently in beta).
APS_CALLBACK_URL=http://localhost:3000/api/auth/callback

# ── ACC / BIM360 Project Context ──────────────────────────
# Account (Hub) ID — found in ACC Admin URL or via Data Management API
ACC_ACCOUNT_ID=your_acc_account_id_here

# ACC Project ID (without the "b." prefix)
ACC_PROJECT_ID=your_acc_project_id_here

# Container ID for Model Coordination
# Retrieve via: GET /bim360/modelset/v3/accounts/{accountId}/containers
MC_CONTAINER_ID=your_mc_container_id_here

# Active coordination space (model set) ID — set this once a space is selected on the Connect tab
MC_MODEL_SET_ID=

# ── Target Folder ─────────────────────────────────────────
# The Docs folder URN where all models are uploaded
# Retrieve via Data Management API: GET /project/v1/hubs/{hub_id}/projects/{project_id}/topFolders
TARGET_FOLDER_URN=urn:adsk.wipprod:fs.folder:co.your_folder_urn_here

# ── Optional Overrides (do not set unless you know what you are doing) ──
# APS API base URL (defaults below are production)
APS_BASE_URL=https://developer.api.autodesk.com
# Leave these UNSET — code defaults to the correct URLs.
# (Older versions of this file shipped the wrong path containing 'modelcoordination/'.
#  If your .env still has those lines, DELETE them.)
# MC_MODELSET_API_BASE=
# MC_CLASH_API_BASE=

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Dry-run mode — if true, prints planned actions but does not call write APIs
DRY_RUN=false
