# ============================================================
# FormaFlow — Environment Variables
# Copy this file to .env and fill in your credentials.
# Never commit the .env file to source control.
# ============================================================

# ── APS / Autodesk Platform Services ──────────────────────
# Obtain from https://aps.autodesk.com/myapps/
APS_CLIENT_ID=your_aps_client_id_here
APS_CLIENT_SECRET=your_aps_client_secret_here

# ── ACC / BIM360 Project Context ──────────────────────────
# Account (Hub) ID — found in ACC Admin URL or via Data Management API
ACC_ACCOUNT_ID=your_acc_account_id_here

# ACC Project ID (without the "b." prefix)
ACC_PROJECT_ID=your_acc_project_id_here

# Container ID for Model Coordination
# Retrieve via: GET /bim360/modelcoordination/modelset/v3/accounts/{accountId}/containers
MC_CONTAINER_ID=your_mc_container_id_here

# ── Target Folder ─────────────────────────────────────────
# The Docs folder URN where all models are uploaded
# Retrieve via Data Management API: GET /project/v1/hubs/{hub_id}/projects/{project_id}/topFolders
TARGET_FOLDER_URN=urn:adsk.wipprod:fs.folder:co.your_folder_urn_here

# ── Optional Overrides ────────────────────────────────────
# APS API base URL (defaults below are production)
APS_BASE_URL=https://developer.api.autodesk.com
MC_MODELSET_API_BASE=https://developer.api.autodesk.com/bim360/modelcoordination/modelset/v3
MC_CLASH_API_BASE=https://developer.api.autodesk.com/bim360/modelcoordination/clash/v3

# Log level: error | warn | info | debug
LOG_LEVEL=info

# Dry-run mode — if true, prints planned actions but does not call write APIs
DRY_RUN=false
