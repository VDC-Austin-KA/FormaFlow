{
  "name": "formaflow",
  "version": "1.0.0",
  "description": "Automated Model Coordination framework for Autodesk Forma / ACC — clash detection, Search Sets, and discipline classification using the APS SDK",
  "type": "module",
  "main": "src/index.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "workflow": "node src/workflow/automated-workflow.js",
    "identify": "node src/model-identification/discipline-classifier.js",
    "generate-search-sets": "node src/search-sets/search-set-generator.js",
    "configure-clashes": "node src/clash-tests/clash-test-configurator.js",
    "process-results": "node src/results/clash-results-processor.js",
    "validate-config": "node src/utils/config-validator.js",
    "test": "node --experimental-vm-modules node_modules/.bin/jest --passWithNoTests",
    "lint": "eslint src/**/*.js"
  },
  "keywords": [
    "autodesk-forma",
    "autodesk-platform-services",
    "aps",
    "acc",
    "clash-detection",
    "model-coordination",
    "bim",
    "search-sets",
    "automation",
    "vdc"
  ],
  "author": "FormaFlow Automation",
  "license": "MIT",
  "dependencies": {
    "@aps_sdk/authentication": "^1.0.0",
    "@aps_sdk/autodesk-sdkmanager": "^1.0.0",
    "@aps_sdk/model-derivative": "^1.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "dotenv": "^16.4.5",
    "express": "^4.22.1",
    "fast-xml-parser": "^5.7.1",
    "js-yaml": "^4.1.0",
    "localtunnel": "^2.0.2",
    "node-fetch": "^3.3.2",
    "winston": "^3.14.2"
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "jest": "^29.7.0"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "references": {
    "aps_sdk": "https://github.com/autodesk-platform-services/aps-sdk-node",
    "clash_sample": "https://github.com/autodesk-platform-services/aps-clash-data-view",
    "clash_pdf_sample": "https://github.com/autodesk-platform-services/aps-clash-data-export-pdf",
    "model_coordination_docs": "https://aps.autodesk.com/en/docs/acc/v1/overview/field-guide/model-coordination/mcfg-clash",
    "postman_collection": "https://aps.autodesk.com/blog/postman-collections-model-coordination-api"
  }
}
